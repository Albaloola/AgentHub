{
  "name": "agenthub",
  "version": "0.2.0",
  "private": false,
  "author": "Omer Elbushra <omaralbushra99@gmail.com>",
  "license": "Apache-2.0",
  "main": "dist/desktop/main.js",
  "bin": {
    "agenthub": "./bin/agenthub.mjs"
  },
  "files": [
    "bin/",
    ".next/standalone/",
    ".next/static/",
    "public/",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "desktop:build-main": "tsc -p desktop/tsconfig.json",
    "desktop:build-next": "cross-env AGENTHUB_BUILD_CPUS=1 next build --webpack && node scripts/copy-standalone.mjs",
    "desktop:build": "npm run desktop:build-next && npm run desktop:build-main",
    "desktop:dev": "concurrently -k \"next dev\" \"npm run desktop:build-main && wait-on http://localhost:3000 && cross-env AGENTHUB_DESKTOP=1 AGENTHUB_DEV_URL=http://localhost:3000 electron dist/desktop/main.js\"",
    "desktop:start": "npm run desktop:build && cross-env AGENTHUB_DESKTOP=1 electron dist/desktop/main.js",
    "desktop:package": "npm run desktop:build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "electron-log": "^5.4.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}
