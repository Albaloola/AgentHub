# AgentHub Configuration
# Copy this to .env.local and adjust as needed

# Database path (defaults to ./data/agenthub.db)
DATABASE_PATH=./data/agenthub.db

# Optional data directory override for web, Docker, or desktop-managed runtime paths
# AGENTHUB_DATA_DIR=/absolute/path/to/agenthub-data

# Server port (default: 3000)
# PORT=3000

# OpenClaw gateway token (required for OpenClaw agents)
OPENCLAW_API_KEY=
